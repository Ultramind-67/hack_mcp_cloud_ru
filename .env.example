# ==========================================
# ⚙️ SERVER CONFIGURATION
# ==========================================
PORT=8000
HOST=0.0.0.0

# ==========================================
# 🧠 LLM PROVIDER (Cloud.ru Evolution)
# ==========================================
# 1. Register/Login at https://console.cloud.ru/
# 2. Go to "Evolution" -> "API Keys" to generate a key.
API_KEY=sk-your_cloud_ru_api_key_here

# ==========================================
# 🔍 WEB SEARCH TOOLS (Google)
# ==========================================
# 1. Create a project and get API Key: https://console.cloud.google.com/apis/credentials
# 2. Enable "Custom Search API" in the Library.
GOOGLE_API_KEY=AIzaSy...your_google_api_key

# 3. Create a search engine: https://programmablesearchengine.google.com/
# 4. Enable "Search the entire web" in settings.
# 5. Copy the "Search engine ID" (cx).
GOOGLE_CSE_ID=0123456789...your_cse_id

# ==========================================
# 🕸️ WEB SCRAPING (Jina AI)
# ==========================================
# Used to convert websites to Markdown for the agent.
# Get a free API key here: https://jina.ai/reader
JINA_API_KEY=jina_...your_key_here

# ==========================================
# 🚚 LOGISTICS PROVIDER (DPD Russia)
# ==========================================
# Requires a business contract with DPD.
# Integration keys can be found in your personal cabinet: https://dpd.ru/
DPD_CLIENT_NUMBER=1001234567
DPD_CLIENT_KEY=your_dpd_integration_key

# ==========================================
# ☁️ CLOUD STORAGE (Yandex Disk)
# ==========================================
# Used to upload CSV reports and generate public links.
# Get an OAuth token here: https://yandex.ru/dev/disk/poligon/
# Or create an app at https://oauth.yandex.ru/
YANDEX_DISK_TOKEN=y0_...your_yandex_token

# ==========================================
# 📧 EMAIL SERVICE (Gmail Example)
# ==========================================
# NOTE: Do NOT use your standard password. Use an App Password!
# Generate here: https://myaccount.google.com/apppasswords
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993

EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_16_digit_app_password

# Timeouts for checking supplier responses (in seconds)
EMAIL_CHECK_TIMEOUT=60
EMAIL_CHECK_INTERVAL=10